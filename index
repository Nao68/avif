function openModal() {
  editingId=null; selectedTags=[]; stagedFiles=[];
  document.getElementById('modalTitle').textContent='🎞 画像を追加';
  document.getElementById('titleInput').value='';
  document.getElementById('descInput').value='';
  document.getElementById('newTagInput').value='';
  document.getElementById('fileInput').value='';
  document.getElementById('previewStrip').innerHTML='';
  document.getElementById('uploadSection').style.display='';
  document.getElementById('titleHint').style.display='';
  renderTagChips();
  document.getElementById('modal').style.display='flex';
}
function openEditModal(id) {
  const it=items.find(x=>x.id===id); if(!it) return;
  editingId=id; selectedTags=[...it.tags]; stagedFiles=[];
  document.getElementById('modalTitle').textContent='✏️ 情報を編集';
  document.getElementById('titleInput').value=it.title;
  document.getElementById('descInput').value=it.desc||'';
  document.getElementById('newTagInput').value='';
  document.getElementById('uploadSection').style.display='none';
  document.getElementById('titleHint').style.display='none';
  renderTagChips();
  document.getElementById('modal').style.display='flex';
}
function closeModal() {
  document.getElementById('modal').style.display='none';
  stagedFiles.forEach(sf=>{ if(sf.blobUrl) URL.revokeObjectURL(sf.blobUrl); });
  stagedFiles=[];
  // 保存ボタンを必ずリセット
  const saveBtn = document.querySelector('#modal .btn-primary');
  if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = '保存する'; }
}
function closeModalOutside(e) { if(e.target.id==='modal') closeModal(); }

// ── file select (modal) ──
async function onFileSelect(e) {
  const files = [...e.target.files].filter(f=>f.type.includes('avif')||f.name.endsWith('.avif'));
  if (!files.length) return;
  await addFilesToStaged(files);
  e.target.value='';
}

async function addFilesToStaged(files) {
  const strip = document.getElementById('previewStrip');
  for (const file of files) {
    const blobUrl = URL.createObjectURL(file);
    const thumbDataUrl = await extractFirstFrame(file);
    const staged = { file, blobUrl, thumbDataUrl, name: file.name };
    stagedFiles.push(staged);

    // preview thumb in modal
    const item = document.createElement('div');
    item.className = 'preview-item';
    const idx = stagedFiles.length - 1;
    const cvs = document.createElement('canvas');
    item.appendChild(cvs);
    if (thumbDataUrl) drawThumbOnCanvas(cvs, thumbDataUrl);
    const rmBtn = document.createElement('button');
    rmBtn.className = 'preview-remove';
    rmBtn.textContent = '✕';
    rmBtn.onclick = () => {
      URL.revokeObjectURL(staged.blobUrl);
      stagedFiles = stagedFiles.filter(s=>s!==staged);
      item.remove();
    };
    item.appendChild(rmBtn);
    strip.appendChild(item);
  }
  // タイトルが未入力なら最初のファイル名をヒントに
  if (!document.getElementById('titleInput').value && files.length===1) {
    document.getElementById('titleInput').value = files[0].name.replace(/\.avif$/i,'');
  }
}

// ── tag chips ──
function renderTagChips() {
  // tagOrderのみを使う（PRESET_TAGSは無視）
  // tagOrderにないアイテムのタグだけ末尾補完
  const extraTags = [...new Set(items.flatMap(it=>it.tags))].filter(t => !tagOrder.includes(t));
  const all = [
    ...tagOrder.filter(t => t !== 'その他'),
    ...extraTags.filter(t => t !== 'その他'),
    'その他'
  ].filter((t,i,a) => a.indexOf(t) === i); // 重複除去
  document.getElementById('tagChips').innerHTML=all.map(tag=>
    `<div class="tag-chip${selectedTags.includes(tag)?' selected':''}" onclick="toggleTagModal('${escHtml(tag)}')">${escHtml(tag)}</div>`
  ).join('');
}
function toggleTagModal(tag) {
  selectedTags=selectedTags.includes(tag)?selectedTags.filter(t=>t!==tag):[...selectedTags,tag];
  renderTagChips();
}
function addCustomTag() {
  const inp=document.getElementById('newTagInput');
  const tag=inp.value.trim(); if(!tag) return;
  if(!selectedTags.includes(tag)) selectedTags.push(tag);
  inp.value=''; renderTagChips();
}

// ── save ──
async function saveItems() {
  const title   = document.getElementById('titleInput').value.trim();
  const desc    = document.getElementById('descInput').value.trim();
  const tagList = selectedTags.length ? selectedTags : ['その他'];

  if (editingId) {
    const it = items.find(x => x.id === editingId); if (!it) return;
    it.title = title || it.title; it.desc = desc; it.tags = tagList;
    await saveMetaOne(it);
    closeModal(); renderDropdown(); renderCards();
    return;
  }

  // 新規追加
  if (!stagedFiles.length) { alert('AVIFファイルを選択してください'); return; }

  // 保存ボタンを無効化して二重送信防止
  const saveBtn = document.querySelector('#modal .btn-primary');
  if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = '保存中...'; }

  for (let i = 0; i < stagedFiles.length; i++) {
    const sf = stagedFiles[i];
    const itemTitle = stagedFiles.length === 1
      ? (title || sf.name.replace(/\.avif$/i, ''))
      : (title ? `${title} ${i + 1}` : sf.name.replace(/\.avif$/i, ''));
    const id = generateId();
    const item = {
      id, name: sf.name, title: itemTitle, desc,
      tags: tagList, favorite: false,
      addedAt: new Date().toISOString(),
      thumbDataUrl: sf.thumbDataUrl,
      blobUrl: sf.blobUrl
    };
    items.unshift(item); // 先頭に追加（新しい順）

    // IndexedDB に保存（ファイル本体 + メタ）
    const buf = await sf.file.arrayBuffer();
    await saveFile(id, buf, sf.file.type || 'image/avif');
    await saveMetaOne(item);
  }

  stagedFiles = []; // staged はクリア（blobUrl は item 側で保持）
  closeModal(); renderDropdown(); renderCards();
  updateStorageBar();
}

