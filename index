<script>
// ═══════════════════════════════════
//  定数
// ═══════════════════════════════════
const HAS_DECODER = typeof ImageDecoder !== 'undefined';
const PRESET_TAGS = ['アニメ','ゲーム','イラスト','写真','キャラクター','背景','エフェクト','UI','その他'];
// カラフルなパレット（彩度・明度を揃えて統一感を保ちつつ多彩に）
const COLOR_PALETTE = [
  '#7c9dff','#34d399','#f472b6','#f59e0b','#a78bfa','#22d3ee',
  '#f87171','#6ee7b7','#fb923c','#e879f9','#4ade80','#38bdf8',
  '#fbbf24','#c084fc','#f43f5e','#2dd4bf','#818cf8','#a3e635',
  '#60a5fa','#fb7185','#34d399','#facc15','#e34d8c','#00c9a7',
];
const TAG_COLORS = {}; // タグ名 → 色のキャッシュ

function getTagColor(tag) {
  if (tag === 'その他') return TAG_COLORS['その他'] || (TAG_COLORS['その他'] = '#6b7280');
  if (TAG_COLORS[tag]) return TAG_COLORS[tag];
  // 使用済み色を除いたパレットから選ぶ
  const used = new Set(Object.values(TAG_COLORS));
  const available = COLOR_PALETTE.filter(c => !used.has(c));
  const pool = available.length > 0 ? available : COLOR_PALETTE;
  // タグ名から一定のインデックスを決定（同じタグは必ず同じ色）
  let h = 0;
  for (const c of tag) h = ((h << 5) - h + c.charCodeAt(0)) | 0;
  const color = pool[Math.abs(h) % pool.length];
  TAG_COLORS[tag] = color;
  return color;
}

// ═══════════════════════════════════
//  状態
// ═══════════════════════════════════
let items        = [];   // { id, name, title, desc, tags, favorite, addedAt, thumbDataUrl, blobUrl }
let editingId    = null;
let selectedTag  = null;
let selectedTags = [];
let currentTab   = 'all';
let bulkMode     = false;
let selectedIds  = new Set();
let bulkTagModalEl = null;
let activePlayer = null;
let stagedFiles  = [];   // { file, blobUrl, thumbDataUrl, name }

// ═══════════════════════════════════
//  IndexedDB ─ 完全永続化
//  objectStore "files" : { id, buf:ArrayBuffer, mime:string }
//  objectStore "meta"  : { id, name, title, desc, tags, favorite, addedAt, thumbDataUrl }
// ═══════════════════════════════════
const DB_NAME    = 'avif_gallery';
const DB_VERSION = 1;
let db = null;

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('files')) d.createObjectStore('files', { keyPath: 'id' });
      if (!d.objectStoreNames.contains('meta'))  d.createObjectStore('meta',  { keyPath: 'id' });
    };
    req.onsuccess = e => resolve(e.target.result);
    req.onerror   = e => reject(e.target.error);
  });
}

function dbTx(storeName, mode = 'readonly') {
  return db.transaction(storeName, mode).objectStore(storeName);
}
function idbGet(store, id) {
  return new Promise((res, rej) => { const r = dbTx(store).get(id); r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e.target.error); });
}
function idbPut(store, value) {
  return new Promise((res, rej) => { const r = dbTx(store, 'readwrite').put(value); r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e.target.error); });
}
function idbDelete(store, id) {
  return new Promise((res, rej) => { const r = dbTx(store, 'readwrite').delete(id); r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e.target.error); });
}
function idbGetAll(store) {
  return new Promise((res, rej) => { const r = dbTx(store).getAll(); r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e.target.error); });
}

// ─ 保存 ─
async function saveMetaOne(it) {
  await idbPut('meta', {
    id: it.id, name: it.name, title: it.title, desc: it.desc,
    tags: it.tags, favorite: it.favorite, addedAt: it.addedAt,
    thumbDataUrl: it.thumbDataUrl,
    views: it.views || 0
  });
}
async function saveFile(id, arrayBuffer, mime) {
  await idbPut('files', { id, buf: arrayBuffer, mime });
}

// ─ 削除 ─
async function deleteFromDB(id) {
  // blobUrlを解放
  const it = items.find(x => x.id === id);
  if (it?.blobUrl) URL.revokeObjectURL(it.blobUrl);
  await Promise.all([idbDelete('files', id), idbDelete('meta', id)]);
}

// ─ 起動時ロード: DB → blobUrl を復元してページに反映 ─
async function loadFromDB() {
  const [metaList, fileList] = await Promise.all([idbGetAll('meta'), idbGetAll('files')]);
  const fileMap = new Map(fileList.map(f => [f.id, f]));
  metaList.sort((a, b) => new Date(b.addedAt) - new Date(a.addedAt));
  for (const m of metaList) {
    const f = fileMap.get(m.id);
    let blobUrl = null;
    if (f) {
      const blob = new Blob([f.buf], { type: f.mime || 'image/avif' });
      blobUrl = URL.createObjectURL(blob);
    }
    items.push({ ...m, blobUrl });
  }
}

function generateId() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }
function fmtDate(ds) {
  if (!ds) return '';
  const d = new Date(ds);
  return `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;
}
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }


// ═══════════════════════════════════
//  First-frame extraction
// ═══════════════════════════════════
async function extractFirstFrame(blobOrFile) {
  // ImageDecoder (Chrome/Edge) → 高精度
  if (HAS_DECODER) {
    try {
      const buf  = await blobOrFile.arrayBuffer();
      const dec  = new ImageDecoder({ data: buf, type: 'image/avif' });
      await dec.tracks.ready;
      const result = await dec.decode({ frameIndex: 0 });
      const bmp  = await createImageBitmap(result.image);
      result.image.close();
      dec.close();
      const cvs  = document.createElement('canvas');
      cvs.width  = bmp.width;
      cvs.height = bmp.height;
      cvs.getContext('2d').drawImage(bmp, 0, 0);
      bmp.close();
      return cvs.toDataURL('image/webp', 0.88);
    } catch(e) {}
  }
  // fallback: <img> → canvas (draws whatever frame, but consistent)
  return new Promise(resolve => {
    const url = URL.createObjectURL(blobOrFile);
    const img = new Image();
    img.onload = () => {
      const cvs = document.createElement('canvas');
      cvs.width  = img.naturalWidth;
      cvs.height = img.naturalHeight;
      cvs.getContext('2d').drawImage(img, 0, 0);
      URL.revokeObjectURL(url);
      resolve(cvs.toDataURL('image/webp', 0.88));
    };
    img.onerror = () => { URL.revokeObjectURL(url); resolve(null); };
    img.src = url;
  });
}

// ═══════════════════════════════════
//  Draw thumb from dataUrl into a canvas element
// ═══════════════════════════════════
function drawThumbOnCanvas(canvas, dataUrl) {
  const img = new Image();
  img.onload = () => {
    canvas.width  = img.naturalWidth;
    canvas.height = img.naturalHeight;
    canvas.getContext('2d').drawImage(img, 0, 0);
  };
  img.src = dataUrl;
}

// ═══════════════════════════════════
//  Dropdown
// ═══════════════════════════════════
function toggleDropdown() {
  const m=document.getElementById('dropdownMenu'), a=document.getElementById('dropdownArrow');
  const open = m.style.display !== 'none';
  m.style.display = open ? 'none' : 'block';
  a.classList.toggle('open', !open);
}
document.addEventListener('click', e => {
  if (!document.getElementById('dropdownWrapper').contains(e.target)) {
    document.getElementById('dropdownMenu').style.display = 'none';
    document.getElementById('dropdownArrow').classList.remove('open');
  }
  if (!document.getElementById('sortDropdownWrapper').contains(e.target)) {
    document.getElementById('sortDropdownMenu').style.display = 'none';
    document.getElementById('sortDropdownArrow').classList.remove('open');
  }
});
function renderDropdown() {
  const usedTags = new Set(items.flatMap(it=>it.tags));
  // tagOrderで並び替え → その他を末尾固定
  const ordered = tagOrder.length
    ? tagOrder.filter(t => usedTags.has(t))
    : [...usedTags];
  const allTags = [...ordered.filter(t => t !== 'その他'), ...ordered.filter(t => t === 'その他' && usedTags.has(t))];
  document.getElementById('dropdownMenu').innerHTML =
    `<div class="dropdown-item ${!selectedTag?'active':''}" onclick="filterByTag(null)">すべて <span class="tag-count">${items.length}</span></div>`+
    allTags.map(tag => {
      const n = items.filter(it=>it.tags.includes(tag)).length;
      return `<div class="dropdown-item ${selectedTag===tag?'active':''}" onclick="filterByTag('${escHtml(tag)}')">${escHtml(tag)} <span class="tag-count">${n}</span></div>`;
    }).join('');
}
function filterByTag(tag) {
  selectedTag = tag;
  document.getElementById('selectedTagLabel').textContent = tag || 'すべてのタグ';
  document.getElementById('dropdownMenu').style.display = 'none';
  document.getElementById('dropdownArrow').classList.remove('open');
  renderDropdown(); renderCards();
}

// ═══════════════════════════════════
//  Tabs
// ═══════════════════════════════════
function switchTab(tab) {
  currentTab = tab;
  ['all','favorite'].forEach(t => document.getElementById(`tab-${t}`).classList.toggle('active', t===tab));
  renderCards();
}
function updateBadges() {
  document.getElementById('badge-all').textContent = items.length;
  document.getElementById('badge-fav').textContent = items.filter(it=>it.favorite).length;
}

// ═══════════════════════════════════
//  Sort — カスタムドロップダウン
// ═══════════════════════════════════
const SORT_OPTIONS = [
  { value: 'added',     icon: '🕐', label: '追加日（新しい）' },
  { value: 'added_asc', icon: '🕰', label: '追加日（古い）' },
  { value: 'views',     icon: '👁', label: '表示回数順' },
  { value: 'alpha',     icon: '🔤', label: 'タイトル A→Z' },
  { value: 'alpha_desc',icon: '🔤', label: 'タイトル Z→A' },
  { value: 'fav',       icon: '⭐', label: 'お気に入り優先' },
  { value: 'random',    icon: '🎲', label: 'ランダム' },
];
let currentSort = 'added';

function renderSortDropdown() {
  document.getElementById('sortDropdownMenu').innerHTML = SORT_OPTIONS.map(opt =>
    `<div class="sort-dropdown-item${opt.value===currentSort?' active':''}" onclick="selectSort('${opt.value}')">
      <span class="sort-item-icon">${opt.icon}</span>${opt.label}
    </div>`
  ).join('');
}
function toggleSortDropdown() {
  const m = document.getElementById('sortDropdownMenu');
  const a = document.getElementById('sortDropdownArrow');
  const open = m.style.display !== 'none';
  if (!open) renderSortDropdown();
  m.style.display = open ? 'none' : 'block';
  a.classList.toggle('open', !open);
}
function selectSort(val) {
  currentSort = val;
  const opt = SORT_OPTIONS.find(o => o.value === val);
  document.getElementById('sortIcon').textContent  = opt.icon;
  document.getElementById('sortLabel').textContent = opt.label;
  document.getElementById('sortDropdownMenu').style.display = 'none';
  document.getElementById('sortDropdownArrow').classList.remove('open');
  renderCards();
}


function sortList(list) {
  const s = currentSort, a = [...list];
  if (s==='added')     return a.sort((x,y)=>new Date(y.addedAt)-new Date(x.addedAt));
  if (s==='added_asc') return a.sort((x,y)=>new Date(x.addedAt)-new Date(y.addedAt));
  if (s==='views')     return a.sort((x,y)=>(y.views||0)-(x.views||0));
  if (s==='alpha')     return a.sort((x,y)=>x.title.localeCompare(y.title,'ja'));
  if (s==='alpha_desc')return a.sort((x,y)=>y.title.localeCompare(x.title,'ja'));
  if (s==='fav')       return a.sort((x,y)=>(y.favorite?1:0)-(x.favorite?1:0));
  if (s==='random')    return a.sort(()=>Math.random()-0.5);
  return a;
}

// ═══════════════════════════════════
//  Render cards
// ═══════════════════════════════════
function renderCards() {
  updateBadges();
  const q = document.getElementById('searchInput').value.toLowerCase();
  let list = [...items];
  if (currentTab==='favorite') list = list.filter(it=>it.favorite);
  if (selectedTag) list = list.filter(it=>it.tags.includes(selectedTag));
  if (q) list = list.filter(it=>(it.title+it.tags.join(' ')+(it.desc||'')).toLowerCase().includes(q));
  list = sortList(list);
  document.getElementById('visibleCount').textContent = list.length;
  const grid = document.getElementById('grid');
  if (bulkMode) grid.classList.add('bulk-mode'); else grid.classList.remove('bulk-mode');

  if (!list.length) {
    grid.innerHTML = `<div class="empty-state">
      <div class="empty-icon">${currentTab==='favorite'?'⭐':'🎞'}</div>
      <div class="empty-title">${currentTab==='favorite'?'お気に入りがありません':'画像がありません'}</div>
      <div class="empty-sub">${currentTab==='all'?'右下の「＋」ボタンから .avif ファイルを追加してください':''}</div>
    </div>`;
    return;
  }

  const fragment = document.createDocumentFragment();
  list.forEach((it, i) => {
    const tagsHtml = it.tags.map(t=>`<span class="thumb-tag" style="background:${getTagColor(t)}44;color:${getTagColor(t)};border:1px solid ${getTagColor(t)}66">${escHtml(t)}</span>`).join('');
    const div = document.createElement('div');
    div.className = `card${it.favorite?' favorited':''}${selectedIds.has(it.id)?' selected':''}`;
    div.dataset.id = it.id;
    div.dataset.action = 'open';
    div.style.animationDelay = Math.min(i,12)*0.025+'s';

    div.innerHTML = `
      <input type="checkbox" class="card-checkbox" data-id="${it.id}" data-action="check" ${selectedIds.has(it.id)?'checked':''}>
      ${it.favorite?'<div class="star-badge">⭐</div>':''}
      <div class="card-thumb" id="thumb-${it.id}">
        <div class="thumb-loading">読み込み中...</div>
      </div>
      <div class="card-hover-actions">
        <div class="act-btn fav${it.favorite?' on':''}" data-id="${it.id}" data-action="fav" title="${it.favorite?'解除':'お気に入り'}">⭐</div>
        <div class="act-btn" data-id="${it.id}" data-action="edit" title="編集">✏️</div>
        <div class="act-btn delete" data-id="${it.id}" data-action="delete" title="削除">🗑️</div>
      </div>
      <div class="card-body">
        <div class="card-title">${escHtml(it.title)}</div>
        ${it.desc?`<div class="card-desc">${escHtml(it.desc)}</div>`:''}
      </div>
      <div class="card-footer">
        <div class="card-meta-info">${fmtDate(it.addedAt)}</div>
        <div class="card-footer-tags">${it.tags.slice(0,2).map(t=>`<span class="card-footer-tag" style="background:${getTagColor(t)}33;color:${getTagColor(t)}">${escHtml(t)}</span>`).join('')}</div>
        <div class="card-views"><span class="card-views-dot"></span>${it.views||0}</div>
      </div>`;
    fragment.appendChild(div);
  });
  grid.innerHTML = '';
  grid.appendChild(fragment);

  // サムネを描画
  list.forEach(it => {
    if (!it.thumbDataUrl) return;
    const thumbDiv = document.getElementById('thumb-'+it.id);
    if (!thumbDiv) return;
    const loading = thumbDiv.querySelector('.thumb-loading');
    const cvs = document.createElement('canvas');
    cvs.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;';
    thumbDiv.insertBefore(cvs, loading);
    drawThumbOnCanvas(cvs, it.thumbDataUrl);
    if (loading) loading.remove();
  });

  // bulk 再適用
  if (bulkMode) {
    selectedIds.forEach(id => {
      const card = document.querySelector(`.card[data-id="${id}"]`);
      if (card) { card.classList.add('selected'); const chk=card.querySelector('.card-checkbox'); if(chk) chk.checked=true; }
    });
    updateBulkLabel();
  }
}

// ── card click dispatcher ──
document.getElementById('grid').addEventListener('click', function(e) {
  const btn = e.target.closest('[data-action]');
  if (!btn) return;
  const action=btn.dataset.action, id=btn.dataset.id;
  if (action==='check')  { e.stopPropagation(); toggleSelect(id); return; }
  if (action==='fav')    { e.stopPropagation(); toggleFav(id);    return; }
  if (action==='edit')   { e.stopPropagation(); openEditModal(id);return; }
  if (action==='delete') { e.stopPropagation(); deleteItem(id);   return; }
  if (action==='open')   { if (!bulkMode) openLightbox(id); else toggleSelect(id); }
});

function toggleFav(id) {
  const it=items.find(x=>x.id===id); if(!it) return;
  it.favorite=!it.favorite;
  saveMetaOne(it);
  renderCards();
}
function deleteItem(id) {
  if (!confirm('この画像を削除しますか？')) return;
  items=items.filter(x=>x.id!==id);
  deleteFromDB(id);
  renderDropdown(); renderCards();
  updateStorageBar();
}

// ═══════════════════════════════════
//  Bulk
// ═══════════════════════════════════
function toggleBulkMode() {
  bulkMode=!bulkMode; selectedIds.clear();
  document.getElementById('bulkBar').style.display=bulkMode?'flex':'none';
  document.getElementById('bulkToggleBtn').classList.toggle('active',bulkMode);
  updateBulkLabel(); renderCards();
}
function toggleSelect(id) {
  if(selectedIds.has(id)) selectedIds.delete(id); else selectedIds.add(id);
  const chk=document.querySelector(`.card-checkbox[data-id="${id}"]`);
  if(chk) chk.checked=selectedIds.has(id);
  const card=document.querySelector(`.card[data-id="${id}"]`);
  if(card) card.classList.toggle('selected',selectedIds.has(id));
  updateBulkLabel();
}
function toggleSelectAll() {
  const chk=document.getElementById('selectAllChk');
  const visible=[...document.querySelectorAll('.card[data-id]')].map(c=>c.dataset.id);
  if(chk.checked) visible.forEach(id=>selectedIds.add(id)); else visible.forEach(id=>selectedIds.delete(id));
  renderCards(); updateBulkLabel();
}
function updateBulkLabel() {
  document.getElementById('selectedCountLabel').textContent=`${selectedIds.size}件選択中`;
  const all=[...document.querySelectorAll('.card[data-id]')].map(c=>c.dataset.id);
  document.getElementById('selectAllChk').checked=all.length>0&&all.every(id=>selectedIds.has(id));
}
function bulkFavorite(val) {
  if(!selectedIds.size) return;
  const changed = items.filter(it=>selectedIds.has(it.id));
  changed.forEach(it=>{ it.favorite=val; saveMetaOne(it); });
  renderCards(); updateBulkLabel();
}
function bulkDelete() {
  if(!selectedIds.size) return;
  if(!confirm(`${selectedIds.size}件の画像を削除しますか？`)) return;
  const toDelete = [...selectedIds];
  items = items.filter(it=>!selectedIds.has(it.id));
  toDelete.forEach(id => deleteFromDB(id));
  selectedIds.clear(); renderDropdown(); renderCards(); updateBulkLabel();
}
function openBulkTagModal() {
  if(!selectedIds.size) return;
  if(!bulkTagModalEl){
    bulkTagModalEl=document.createElement('div');
    bulkTagModalEl.className='modal-overlay';
    bulkTagModalEl.onclick=e=>{if(e.target===bulkTagModalEl) closeBulkTagModal();};
    document.body.appendChild(bulkTagModalEl);
  }
  const allTags=[...new Set([...PRESET_TAGS,...items.flatMap(it=>it.tags)])];
  bulkTagModalEl.innerHTML=`<div class="bulk-tag-modal" onclick="event.stopPropagation()">
    <div class="modal-title">🏷️ タグを一括変更 (${selectedIds.size}件)</div>
    <div class="form-group"><label class="form-label">追加するタグ</label><div class="tag-chips" id="bulkAddTags">${allTags.map(t=>`<div class="tag-chip" data-tag="${escHtml(t)}" onclick="this.classList.toggle('selected')">${escHtml(t)}</div>`).join('')}</div></div>
    <div class="form-group" style="margin-top:12px"><label class="form-label">削除するタグ</label><div class="tag-chips" id="bulkRemoveTags">${allTags.map(t=>`<div class="tag-chip" data-tag="${escHtml(t)}" onclick="this.classList.toggle('selected');this.classList.toggle('danger-chip',this.classList.contains('selected'))">${escHtml(t)}</div>`).join('')}</div></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeBulkTagModal()">キャンセル</button>
      <button class="btn btn-primary" onclick="applyBulkTags()">適用する</button>
    </div>
  </div>`;
  bulkTagModalEl.style.display='flex';
}
function closeBulkTagModal() { if(bulkTagModalEl) bulkTagModalEl.style.display='none'; }
async function applyBulkTags() {
  const add=[...document.querySelectorAll('#bulkAddTags .tag-chip.selected')].map(e=>e.dataset.tag);
  const rem=[...document.querySelectorAll('#bulkRemoveTags .tag-chip.selected')].map(e=>e.dataset.tag);
  items.forEach(it=>{
    if(!selectedIds.has(it.id)) return;
    add.forEach(t=>{if(!it.tags.includes(t)) it.tags.push(t);});
    it.tags=it.tags.filter(t=>!rem.includes(t));
    if(!it.tags.length) it.tags=['その他'];
  });
  await Promise.all(items.filter(it=>selectedIds.has(it.id)).map(it=>saveMetaOne(it)));
  closeBulkTagModal(); renderDropdown(); renderCards();
}

