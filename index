});

// ═══════════════════════════════════
//  Lightbox — ImageDecoder playback
// ═══════════════════════════════════
const lightbox   = document.getElementById('lightbox');
const lbCanvas   = document.getElementById('lb-canvas');
const lbImg      = document.getElementById('lb-img');
const lbFrameInfo= document.getElementById('lb-frameinfo');
const lbTitle    = document.getElementById('lb-title');
const lbName     = document.getElementById('lb-name');

function openLightbox(id) {
  const it=items.find(x=>x.id===id); if(!it) return;
  if(!it.blobUrl) {
    // DBからblobUrlを復元（念のため）
    idbGet('files', id).then(f => {
      if (f) {
        const blob = new Blob([f.buf], { type: f.mime || 'image/avif' });
        it.blobUrl = URL.createObjectURL(blob);
        openLightbox(id);
      }
    });
    return;
  }
  // 表示回数カウント
  it.views = (it.views || 0) + 1;
  saveMetaOne(it);

  lbTitle.textContent = it.title;
  lbName.textContent  = it.name;
  lightbox.classList.add('open');
  document.body.style.overflow='hidden';
  syncFsIcon();

  if (HAS_DECODER) startImageDecoder(it.blobUrl);
  else {
    lbCanvas.style.display='none';
    lbImg.style.display='';
    lbImg.src=it.blobUrl;
    lbFrameInfo.textContent='<img> モード';
  }
}

function closeLightbox() {
  stopPlayer();
  if(document.fullscreenElement||document.webkitFullscreenElement) exitFs().then(_doLbClose);
  else _doLbClose();
}
function _doLbClose() {
  lightbox.classList.remove('open');
  lbImg.src='';
  lbCanvas.getContext('2d').clearRect(0,0,lbCanvas.width,lbCanvas.height);
  lbFrameInfo.textContent='';
  document.body.style.overflow='';
}

function stopPlayer() {
  if(activePlayer){ activePlayer.cancel(); activePlayer=null; }
}

async function startImageDecoder(blobUrl) {
  stopPlayer();
  lbCanvas.style.display=''; lbImg.style.display='none';
  lbFrameInfo.textContent='読み込み中…';

  let cancelled=false, rafId=null, decoder=null;
  const player={ cancel(){ cancelled=true; if(rafId) cancelAnimationFrame(rafId); try{decoder?.close();}catch(_){} } };
  activePlayer=player;

  try {
    const resp   = await fetch(blobUrl);
    const blob   = await resp.blob();
    decoder = new ImageDecoder({ data: blob.stream(), type:'image/avif' });
    await decoder.tracks.ready;
    await decoder.completed.catch(()=>{});
    if(cancelled) return;

    const frameCount = decoder.tracks.selectedTrack.frameCount;
    const first = await decoder.decode({ frameIndex:0 });
    if(cancelled){ first.image.close(); return; }

    lbCanvas.width  = first.image.displayWidth;
    lbCanvas.height = first.image.displayHeight;
    first.image.close();

    const ctx = lbCanvas.getContext('2d', { alpha:true });

    if (frameCount <= 1) {
      const r = await decoder.decode({ frameIndex:0 });
      if(cancelled){ r.image.close(); return; }
      ctx.drawImage(r.image, 0, 0);
      r.image.close();
      lbFrameInfo.textContent='静止画';
      return;
    }

    lbFrameInfo.textContent=`${frameCount} フレーム — デコード中…`;
    const frames=[];
    for(let i=0;i<frameCount;i++){
      if(cancelled) return;
      const res = await decoder.decode({ frameIndex:i });
      if(cancelled){ res.image.close(); return; }
      const bmp = await createImageBitmap(res.image);
      const dur = res.image.duration!=null ? res.image.duration/1000 : 100;
      res.image.close();
      frames.push({ bmp, dur });
    }
    if(cancelled){ frames.forEach(f=>f.bmp.close()); return; }

    lbFrameInfo.textContent=`${frameCount} フレーム | ⚡ ImageDecoder`;
    const W=lbCanvas.width, H=lbCanvas.height;
    let fi=0, last=null, elapsed=0;

    const origCancel=player.cancel.bind(player);
    player.cancel=()=>{ origCancel(); frames.forEach(f=>{try{f.bmp.close();}catch(_){}}); };

    function loop(ts){
      if(cancelled) return;
      if(last===null) last=ts;
      const delta=ts-last; last=ts; elapsed+=delta;
      if(elapsed>=0){
        ctx.clearRect(0,0,W,H);
        ctx.drawImage(frames[fi].bmp,0,0);
        elapsed-=frames[fi].dur;
        if(elapsed>=frames[fi].dur) elapsed=0;
        fi=(fi+1)%frameCount;
      }
      rafId=requestAnimationFrame(loop);
    }
    rafId=requestAnimationFrame(loop);

  } catch(err) {
    if(cancelled) return;
    console.warn('ImageDecoder error, fallback:', err);
    lbCanvas.style.display='none'; lbImg.style.display='';
    lbImg.src=blobUrl;
    lbFrameInfo.textContent='フォールバック (<img>)';
  }
}

// ── Fullscreen ──
function toggleFullscreen() {
  if(document.fullscreenElement||document.webkitFullscreenElement) exitFs(); else enterFs();
}
function enterFs() {
  const el=lbCanvas.style.display!=='none'?lbCanvas:lbImg;
  if(el.requestFullscreen) return el.requestFullscreen();
  if(el.webkitRequestFullscreen) return Promise.resolve(el.webkitRequestFullscreen());
  return Promise.resolve();
}
function exitFs() {
  if(document.exitFullscreen) return document.exitFullscreen();
  if(document.webkitExitFullscreen) return Promise.resolve(document.webkitExitFullscreen());
  return Promise.resolve();
}
function syncFsIcon() {
  const active=!!(document.fullscreenElement||document.webkitFullscreenElement);
  document.getElementById('fs-icon-expand').style.display  =active?'none':'';
  document.getElementById('fs-icon-compress').style.display=active?'':'none';
  // canvas サイズ調整
  if(active){
    lbCanvas.style.cssText='max-width:100vw;max-height:100vh;width:100vw;height:100vh;border-radius:0;box-shadow:none;background:#000;object-fit:contain;';
  } else {
    lbCanvas.style.cssText='max-width:88vw;max-height:80vh;border-radius:10px;box-shadow:0 24px 80px rgba(0,0,0,0.9);will-change:transform;transform:translateZ(0);';
  }
}
document.addEventListener('fullscreenchange', syncFsIcon);
document.addEventListener('webkitfullscreenchange', syncFsIcon);

document.addEventListener('keydown', e => {
  if(!lightbox.classList.contains('open')) return;
  if(e.key==='Escape' && !document.fullscreenElement && !document.webkitFullscreenElement) closeLightbox();
  if(e.key==='f'||e.key==='F') toggleFullscreen();
});
lightbox.addEventListener('click', e => { if(e.target===lightbox) closeLightbox(); });

// ═══════════════════════════════════
//  Tag Manager
// ═══════════════════════════════════
let tagOrder = []; // 全タグの順序を管理（localStorage永続化）
let dragSrcIdx = null;

function saveTagOrder() {
  localStorage.setItem('avif_tag_order', JSON.stringify(tagOrder));
}
function loadTagOrder() {
  try {
    const raw = localStorage.getItem('avif_tag_order');
    if (raw) tagOrder = JSON.parse(raw);
  } catch(e) {}
}

// tagOrderを正規化: itemsの使用中タグを補完し、その他を末尾に固定
function normalizeTagOrder() {
  // tagOrderになくてitemsで使われているタグをその他の前に追加
  const allUsed = [...new Set(items.flatMap(it => it.tags))];
  allUsed.forEach(t => {
    if (!tagOrder.includes(t)) {
      const sonoIdx = tagOrder.indexOf('その他');
      if (sonoIdx !== -1) tagOrder.splice(sonoIdx, 0, t);
      else tagOrder.push(t);
    }
  });
  // その他が未登録なら追加
  if (!tagOrder.includes('その他')) tagOrder.push('その他');
  // その他を末尾に移動
  tagOrder = [...tagOrder.filter(t => t !== 'その他'), 'その他'];
}

function getAllTags() {
  // itemsから使われているタグを収集、tagOrderで並び替え
  const usedTags = [...new Set(items.flatMap(it => it.tags))];
  // tagOrderにないものを末尾に追加
  usedTags.forEach(t => { if (!tagOrder.includes(t)) tagOrder.push(t); });
  // tagOrderにあるがusedTagsにないものは除外しない（未使用タグも管理できるように）
  return tagOrder.filter(t => usedTags.includes(t) || PRESET_TAGS.includes(t));
}

function openTagManager() {
  // 既存の tagOrder を壊さず、足りないタグだけ補完
  normalizeTagOrder();
  renderTagManagerList();
  document.getElementById('tagManagerModal').style.display = 'flex';
  document.getElementById('newGlobalTagInput').value = '';
}
function closeTagManager() {
  document.getElementById('tagManagerModal').style.display = 'none';
  renderDropdown();
  renderCards();
  renderTagChips();
}
function applyAndCloseTagManager() {
  normalizeTagOrder();
  saveTagOrder();
  document.getElementById('tagManagerModal').style.display = 'none';
  renderDropdown();
  renderCards();
  renderTagChips();
}
function closeTagManagerOutside(e) {
  if (e.target.id === 'tagManagerModal') closeTagManager();
}

function renderTagManagerList() {
  const list = document.getElementById('tagManagerList');
  // tagOrderにある全タグを表示（未使用も含む）
  const tags = [...tagOrder];

  list.innerHTML = '';
  tags.forEach((tag, i) => {
    const count = items.filter(it => it.tags.includes(tag)).length;
    const color = getTagColor(tag);
    const row = document.createElement('div');
    row.className = 'tag-manager-row';
    row.draggable = true;
    row.dataset.idx = i;
    row.innerHTML = `
      <span class="tag-drag-handle">⠿</span>
      <span class="tag-manager-dot" style="background:${color}"></span>
      <input class="tag-manager-name" value="${escHtml(tag)}" data-orig="${escHtml(tag)}"
        onblur="renameTag(this)" onkeydown="if(event.key==='Enter')this.blur()">
      <span class="tag-manager-count">${count}件</span>
      <button class="tag-manager-delete" onclick="deleteTag('${escHtml(tag)}')" title="削除">✕</button>`;

    // Drag & drop for reorder
    row.addEventListener('dragstart', e => {
      dragSrcIdx = i;
      e.dataTransfer.effectAllowed = 'move';
      row.style.opacity = '0.4';
    });
    row.addEventListener('dragend', () => { row.style.opacity = ''; });
    row.addEventListener('dragover', e => { e.preventDefault(); row.classList.add('drag-over'); });
    row.addEventListener('dragleave', () => row.classList.remove('drag-over'));
    row.addEventListener('drop', e => {
      e.preventDefault();
      row.classList.remove('drag-over');
      if (dragSrcIdx === null || dragSrcIdx === i) return;
      const [moved] = tagOrder.splice(dragSrcIdx, 1);
      tagOrder.splice(i, 0, moved);
      dragSrcIdx = null;
      renderTagManagerList();
    });

    list.appendChild(row);
  });
}

function renameTag(input) {
  const oldTag = input.dataset.orig;
  const newTag = input.value.trim();
  if (!newTag || newTag === oldTag) { input.value = oldTag; return; }
  // 重複チェック
  if (tagOrder.includes(newTag)) { alert(`「${newTag}」はすでに存在します`); input.value = oldTag; return; }
  // itemsの全タグを更新
  items.forEach(it => {
    const idx = it.tags.indexOf(oldTag);
    if (idx !== -1) { it.tags[idx] = newTag; saveMetaOne(it); }
  });
  // tagOrderを更新
  const oi = tagOrder.indexOf(oldTag);
  if (oi !== -1) tagOrder[oi] = newTag;
  input.dataset.orig = newTag;
  renderTagManagerList();
}

function deleteTag(tag) {
  const count = items.filter(it => it.tags.includes(tag)).length;
  const msg = count > 0
    ? `「${tag}」を削除しますか？\n${count}件の画像からこのタグが外れます。`
    : `「${tag}」を削除しますか？`;
  if (!confirm(msg)) return;
  items.forEach(it => {
    if (it.tags.includes(tag)) {
      it.tags = it.tags.filter(t => t !== tag);
      if (!it.tags.length) it.tags = ['その他'];
      saveMetaOne(it);
    }
  });
  tagOrder = tagOrder.filter(t => t !== tag);
  renderTagManagerList();
}

function addGlobalTag() {
  const inp = document.getElementById('newGlobalTagInput');
  const tag = inp.value.trim();
  if (!tag) return;
  if (tagOrder.includes(tag)) { alert(`「${tag}」はすでに存在します`); inp.select(); return; }
  // その他の直前に挿入（末尾固定を維持）
  const sonoIdx = tagOrder.indexOf('その他');
  if (sonoIdx !== -1) tagOrder.splice(sonoIdx, 0, tag);
  else tagOrder.push(tag);
  inp.value = '';
  inp.focus();
  renderTagManagerList();
  renderDropdown();
  renderTagChips();
}

// ═══════════════════════════════════
//  Storage Usage Bar
// ═══════════════════════════════════
function fmtBytes(bytes) {
  if (bytes < 1024)       return bytes + ' B';
  if (bytes < 1024**2)    return (bytes/1024).toFixed(1) + ' KB';
  if (bytes < 1024**3)    return (bytes/1024**2).toFixed(1) + ' MB';
  return (bytes/1024**3).toFixed(2) + ' GB';
}

async function updateStorageBar() {
  if (!navigator.storage?.estimate) return;
  try {
    const { usage, quota } = await navigator.storage.estimate();
    if (!quota) return;
    const pct = Math.min((usage / quota) * 100, 100);
    const bar   = document.getElementById('storageBarUsed');
    const pctEl = document.getElementById('storagePct');
    const usedEl  = document.getElementById('storageUsedLabel');
    const totalEl = document.getElementById('storageTotalLabel');
    if (!bar) return;

    bar.style.width = pct + '%';
    bar.className = 'storage-bar-used' + (pct >= 90 ? ' danger' : pct >= 70 ? ' warn' : '');
    pctEl.textContent = pct.toFixed(1) + '%';
    pctEl.className   = 'storage-pct' + (pct >= 90 ? ' danger' : pct >= 70 ? ' warn' : '');
    usedEl.textContent  = fmtBytes(usage);
    totalEl.textContent = fmtBytes(quota);
  } catch(e) {}
}

// ═══════════════════════════════════
//  Boot — IndexedDB を開いてから描画
// ═══════════════════════════════════
(async () => {
  // ローディング表示
  document.getElementById('grid').innerHTML =
    '<div class="empty-state"><div class="empty-icon">⏳</div><div class="empty-title">読み込み中...</div></div>';
  try {
    db = await openDB();
    await loadFromDB();
  } catch(e) {
    console.error('IndexedDB error:', e);
  }
  loadTagOrder();      // 保存済みtagOrderを復元
  // 初回のみPRESET_TAGSで初期化（localStorageに何もない場合）
  if (tagOrder.length === 0) {
    tagOrder = [...PRESET_TAGS];
  }
  normalizeTagOrder(); // 新規タグ補完 & その他を末尾に
  renderDropdown();
  renderCards();
  updateStorageBar();
})();
</script>
