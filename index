<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AVIF Gallery</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0c0d11;
  --surface: #13151c;
  --surface2: #1a1d28;
  --surface3: #21253a;
  --border: #252936;
  --border2: #2e3347;
  --text: #e4e6f0;
  --text2: #7a82a0;
  --accent: #7c9dff;
  --accent2: #a78bfa;
  --gold: #f59e0b;
  --red: #f04f4f;
  --green: #34d399;
  --radius: 14px;
  --radius-sm: 9px;
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
  --shadow-lg: 0 16px 56px rgba(0,0,0,0.65);
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

/* ── HEADER ── */
.header {
  background: rgba(12,13,17,0.92);
  border-bottom: 1px solid var(--border);
  padding: 13px 24px;
  display: flex; align-items: center; gap: 12px;
  position: sticky; top: 0; z-index: 100;
  backdrop-filter: blur(16px);
  flex-wrap: wrap;
}
.logo { display: flex; align-items: center; gap: 9px; flex-shrink: 0; }
.logo-icon {
  width: 32px; height: 32px; border-radius: 9px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
}
.logo-text { font-size: 16px; font-weight: 700; }
.logo-text span { color: var(--accent); }

.header-controls { display: flex; align-items: center; gap: 8px; flex: 1; flex-wrap: wrap; }

/* tag filter dropdown */
.dropdown-wrapper { position: relative; }
.dropdown-btn {
  display: flex; align-items: center; gap: 7px;
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 7px 12px;
  font-family: inherit; font-size: 13px; font-weight: 500;
  color: var(--text); cursor: pointer; transition: all 0.15s; white-space: nowrap;
}
.dropdown-btn:hover { border-color: var(--accent); }
.dropdown-arrow { font-size: 9px; color: var(--text2); transition: transform 0.18s; }
.dropdown-arrow.open { transform: rotate(180deg); }
.dropdown-menu {
  position: absolute; top: calc(100% + 5px); left: 0;
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); box-shadow: var(--shadow-lg);
  min-width: 200px; z-index: 300; overflow: hidden;
  animation: fadeDown 0.14s ease;
}
@keyframes fadeDown { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:none} }
.dropdown-item {
  padding: 9px 13px; font-size: 13px; cursor: pointer;
  display: flex; align-items: center; justify-content: space-between;
  transition: background 0.1s; color: var(--text2);
}
.dropdown-item:hover { background: var(--surface2); color: var(--text); }
.dropdown-item.active { background: rgba(124,157,255,0.1); color: var(--accent); font-weight: 600; }
.tag-count { background: var(--border2); border-radius: 20px; padding: 1px 7px; font-size: 11px; font-weight: 600; }
.active .tag-count { background: var(--accent); color: white; }

/* sort custom dropdown */
.sort-dropdown-wrapper { position: relative; }
.sort-dropdown-btn {
  display: flex; align-items: center; gap: 7px;
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 7px 12px;
  font-family: inherit; font-size: 13px; font-weight: 500;
  color: var(--text); cursor: pointer; transition: all 0.15s; white-space: nowrap;
  min-width: 160px;
}
.sort-dropdown-btn:hover { border-color: var(--accent); }
.sort-dropdown-arrow { font-size: 9px; color: var(--text2); transition: transform 0.18s; margin-left: auto; }
.sort-dropdown-arrow.open { transform: rotate(180deg); }
.sort-dropdown-menu {
  position: absolute; top: calc(100% + 5px); left: 0;
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); box-shadow: var(--shadow-lg);
  min-width: 180px; z-index: 300; overflow: hidden;
  animation: fadeDown 0.14s ease;
}
.sort-dropdown-item {
  padding: 9px 13px; font-size: 13px; cursor: pointer;
  display: flex; align-items: center; gap: 8px;
  transition: background 0.1s; color: var(--text2);
}
.sort-dropdown-item:hover { background: var(--surface2); color: var(--text); }
.sort-dropdown-item.active { background: rgba(124,157,255,0.1); color: var(--accent); font-weight: 600; }
.sort-item-icon { font-size: 13px; width: 18px; text-align: center; flex-shrink: 0; }

.search-box { flex: 1; max-width: 260px; position: relative; }
.search-box input {
  width: 100%; background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 7px 12px 7px 32px;
  font-family: inherit; font-size: 13px; color: var(--text); outline: none;
  transition: border-color 0.15s;
}
.search-box input::placeholder { color: var(--text2); }
.search-box input:focus { border-color: var(--accent); }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text2); font-size: 13px; pointer-events: none; }

.hdr-btn {
  display: flex; align-items: center; gap: 5px;
  padding: 7px 12px; border-radius: var(--radius-sm);
  font-family: inherit; font-size: 13px; font-weight: 600;
  cursor: pointer; border: 1px solid var(--border2);
  background: var(--surface2); color: var(--text);
  transition: all 0.15s; white-space: nowrap;
}
.hdr-btn:hover { border-color: var(--accent); color: var(--accent); }
.hdr-btn.active { background: var(--accent); color: white; border-color: var(--accent); }

/* ── TABS ── */
.tabs {
  display: flex; gap: 2px; padding: 10px 24px 0;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}
.tab {
  padding: 8px 15px; font-size: 13px; font-weight: 500;
  color: var(--text2); cursor: pointer;
  border-radius: 8px 8px 0 0;
  border: 1px solid transparent; border-bottom: none;
  transition: all 0.14s; display: flex; align-items: center; gap: 5px;
}
.tab:hover { color: var(--text); background: var(--surface2); }
.tab.active { color: var(--accent); background: var(--bg); border-color: var(--border); position: relative; }
.tab.active::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:1px; background:var(--bg); }
.tab-badge { background: var(--border2); color: var(--text2); border-radius: 20px; padding: 1px 6px; font-size: 11px; font-weight: 600; }
.tab.active .tab-badge { background: var(--accent); color: white; }
.badge-gold { background: var(--gold) !important; color: white !important; }

/* ── BULK BAR ── */
.bulk-bar {
  background: var(--surface2); border-bottom: 1px solid var(--border2);
  padding: 9px 24px; display: flex; align-items: center; gap: 9px; flex-wrap: wrap;
  position: sticky; top: 55px; z-index: 90;
  animation: slideDown 0.18s ease;
}
@keyframes slideDown { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:none} }
.bulk-btn {
  padding: 5px 12px; border-radius: 7px;
  font-family: inherit; font-size: 12px; font-weight: 600;
  cursor: pointer; border: 1px solid var(--border2);
  background: var(--surface3); color: var(--text);
  transition: all 0.14s; white-space: nowrap;
}
.bulk-btn:hover { border-color: var(--accent); color: var(--accent); }
.bulk-btn.danger:hover { border-color: var(--red); color: var(--red); }
.bulk-cancel { margin-left: auto; padding: 5px 12px; border-radius: 7px; font-family: inherit; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid var(--border2); background: transparent; color: var(--text2); transition: all 0.14s; }
.bulk-cancel:hover { background: var(--surface3); color: var(--text); }

/* ── MAIN ── */
.main { padding: 20px 24px 80px; max-width: 1600px; margin: 0 auto; }
.stats-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; font-size: 13px; color: var(--text2); }
.stats-bar strong { color: var(--text); }

/* ── GRID ── */
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }

/* ── CARD ── */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  animation: cardIn 0.3s ease both;
  position: relative;
}
@keyframes cardIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
.card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: var(--border2); }
.card.favorited { border-color: rgba(245,158,11,0.5); }
.card.selected  { outline: 2px solid var(--accent); outline-offset: 2px; }

/* checkbox */
.card-checkbox {
  position: absolute; top: 9px; left: 9px; z-index: 10;
  width: 17px; height: 17px; cursor: pointer;
  accent-color: var(--accent); display: none;
}
.bulk-mode .card-checkbox { display: block; }
.bulk-mode .card-hover-actions { display: none !important; }

/* ── THUMBNAIL ── */
.card-thumb {
  width: 100%; aspect-ratio: 16/10;
  position: relative; overflow: hidden;
  background: var(--surface2);
}
/* canvas が first-frame を描画 */
.card-thumb canvas {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.card:hover .card-thumb canvas { transform: scale(1.04); }

/* loading placeholder */
.thumb-loading {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text2);
  background: linear-gradient(90deg, var(--surface2) 25%, var(--surface3) 50%, var(--surface2) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
}
@keyframes shimmer { to { background-position: -200% 0; } }

/* tag chips on thumb */
.thumb-tags {
  position: absolute; bottom: 7px; left: 7px;
  display: flex; gap: 3px; flex-wrap: wrap;
  max-width: calc(100% - 14px);
  pointer-events: none;
}
.thumb-tag {
  padding: 2px 7px; border-radius: 20px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
  backdrop-filter: blur(6px);
}

/* star / fav */
.star-badge { position: absolute; top: 8px; right: 8px; font-size: 13px; pointer-events: none; filter: drop-shadow(0 1px 3px rgba(0,0,0,0.6)); }

/* hover action buttons on thumb */
.card-hover-actions {
  position: absolute; top: 7px; right: 7px;
  display: none; flex-direction: column; gap: 4px;
}
.card:hover .card-hover-actions { display: flex; }
.act-btn {
  width: 28px; height: 28px; border-radius: 7px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(0,0,0,0.6); color: white;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; font-size: 12px; transition: all 0.14s;
  backdrop-filter: blur(6px);
}
.act-btn:hover        { background: var(--accent);  border-color: var(--accent); }
.act-btn.fav:hover    { background: var(--gold);    border-color: var(--gold); }
.act-btn.fav.on       { background: rgba(245,158,11,0.75); border-color: var(--gold); }
.act-btn.delete:hover { background: var(--red);     border-color: var(--red); }

/* ── CARD BODY ── */
.card-body { padding: 10px 12px 4px; }
.card-title {
  font-size: 13px; font-weight: 600; line-height: 1.35;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 3px;
}
.card-desc {
  font-size: 11px; color: var(--text2); line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; min-height: 0;
}

/* ── CARD FOOTER ── */
.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 6px 12px 9px; gap: 6px;
}
.card-meta-info { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text2); flex-shrink: 0; }
.fav-indicator { font-size: 11px; }
.card-footer-tags { display: flex; gap: 3px; flex-wrap: wrap; flex: 1; }
.card-footer-tag {
  padding: 1px 6px; border-radius: 20px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
}
.card-views {
  font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text2);
  flex-shrink: 0; display: flex; align-items: center; gap: 3px;
}
.card-views-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); opacity: 0.6; }

/* ── EMPTY ── */
.empty-state { text-align: center; padding: 80px 20px; color: var(--text2); grid-column: 1/-1; }
.empty-icon  { font-size: 44px; margin-bottom: 12px; }
.empty-title { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
.empty-sub   { font-size: 13px; }

/* ── DROP OVERLAY (full page) ── */
#drop-overlay {
  position: fixed; inset: 0; z-index: 800;
  background: rgba(12,13,17,0.88);
  backdrop-filter: blur(8px);
  display: none;
  align-items: center; justify-content: center;
  flex-direction: column; gap: 12px;
  border: 3px dashed var(--accent);
  pointer-events: none;
}
#drop-overlay.active { display: flex; }
.drop-overlay-icon { font-size: 52px; }
.drop-overlay-text { font-size: 22px; font-weight: 700; color: var(--accent); letter-spacing: 0.05em; }
.drop-overlay-sub  { font-family: 'DM Mono', monospace; font-size: 13px; color: var(--text2); }

/* ── FAB ── */
.fab {
  position: fixed; bottom: 24px; right: 24px;
  width: 50px; height: 50px; border-radius: 14px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: white; border: none; font-size: 22px; cursor: pointer;
  box-shadow: 0 6px 24px rgba(124,157,255,0.45);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; z-index: 300;
}
.fab:hover { transform: scale(1.08) rotate(90deg); box-shadow: 0 10px 32px rgba(124,157,255,0.6); }

/* ── MODAL ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.75);
  backdrop-filter: blur(8px); z-index: 500;
  display: flex; align-items: center; justify-content: center;
  animation: fadeIn 0.16s ease;
}
@keyframes fadeIn { from{opacity:0} to{opacity:1} }
.modal {
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: 18px; padding: 24px;
  width: 480px; max-width: 96vw; max-height: 92vh; overflow-y: auto;
  box-shadow: 0 32px 100px rgba(0,0,0,0.7);
  animation: slideUp 0.2s ease;
}
.modal::-webkit-scrollbar { width: 5px; }
.modal::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
@keyframes slideUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }

.modal-title { font-size: 17px; font-weight: 700; margin-bottom: 18px; }

/* upload zone in modal */
.upload-zone {
  border: 2px dashed var(--border2); border-radius: var(--radius-sm);
  padding: 24px; text-align: center; cursor: pointer;
  transition: all 0.18s; position: relative; overflow: hidden;
  background: var(--surface2);
}
.upload-zone:hover, .upload-zone.drag-over { border-color: var(--accent); background: rgba(124,157,255,0.06); }
.upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.upload-icon { font-size: 28px; margin-bottom: 6px; }
.upload-label { font-size: 13px; color: var(--text2); }
.upload-label strong { color: var(--accent); }

/* preview strip */
.preview-strip {
  display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px;
}
.preview-item {
  position: relative; width: 70px; height: 52px;
  border-radius: 7px; overflow: hidden;
  border: 1px solid var(--border2);
  background: var(--surface2);
}
.preview-item canvas { width: 100%; height: 100%; object-fit: cover; }
.preview-item .preview-remove {
  position: absolute; top: 2px; right: 2px;
  width: 16px; height: 16px; border-radius: 4px;
  background: rgba(0,0,0,0.7); color: white;
  font-size: 9px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; border: none; transition: background 0.12s;
}
.preview-item .preview-remove:hover { background: var(--red); }

.form-group  { margin-bottom: 13px; }
.form-label  { display: block; font-size: 11px; font-weight: 600; color: var(--text2); margin-bottom: 5px; letter-spacing: 0.06em; text-transform: uppercase; }
.form-input  {
  width: 100%; background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 8px 11px;
  font-family: inherit; font-size: 13px; color: var(--text); outline: none;
  transition: border-color 0.15s;
}
.form-input::placeholder { color: var(--text2); }
.form-input:focus { border-color: var(--accent); }
textarea.form-input { resize: vertical; min-height: 58px; }

.tag-chips { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 4px; }
.tag-chip {
  padding: 3px 9px; border-radius: 20px; font-size: 12px;
  background: var(--surface2); border: 1px solid var(--border2);
  cursor: pointer; font-weight: 500; transition: all 0.13s; color: var(--text2);
}
.tag-chip:hover:not(.selected) { border-color: var(--accent); color: var(--text); }
.tag-chip.selected { background: var(--accent); color: white; border-color: var(--accent); }
.danger-chip { background: rgba(240,79,79,0.1) !important; border-color: var(--red) !important; color: var(--red) !important; }
.new-tag-row { display: flex; gap: 6px; margin-top: 7px; }

.modal-actions { display: flex; gap: 8px; margin-top: 18px; justify-content: flex-end; }
.btn { padding: 8px 17px; border-radius: var(--radius-sm); font-family: inherit; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.14s; border: none; }
.btn-ghost   { background: var(--surface2); color: var(--text2); border: 1px solid var(--border2); }
.btn-ghost:hover { background: var(--surface3); color: var(--text); }
.btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: white; box-shadow: 0 2px 12px rgba(124,157,255,0.3); }
.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(124,157,255,0.45); }

/* tag manager */
.tag-manager-row {
  display: flex; align-items: center; gap: 8px;
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 8px 10px;
  cursor: grab; transition: background 0.15s;
  user-select: none;
}
.tag-manager-row:active { cursor: grabbing; }
.tag-manager-row.drag-over { border-color: var(--accent); background: rgba(124,157,255,0.08); }
.tag-drag-handle { color: var(--text2); font-size: 14px; flex-shrink: 0; cursor: grab; }
.tag-manager-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.tag-manager-name {
  flex: 1; font-size: 13px; font-weight: 600;
  border: none; background: transparent; color: var(--text);
  font-family: inherit; outline: none; min-width: 0;
}
.tag-manager-name:focus { color: var(--accent); }
.tag-manager-count { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text2); flex-shrink: 0; }
.tag-manager-delete {
  width: 24px; height: 24px; border-radius: 6px; border: none;
  background: transparent; color: var(--text2); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; transition: all 0.13s; flex-shrink: 0;
}
.tag-manager-delete:hover { background: rgba(240,79,79,0.15); color: var(--red); }

/* bulk tag modal */
.bulk-tag-modal {
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: 18px; padding: 24px; width: 400px; max-width: 96vw;
  box-shadow: 0 32px 100px rgba(0,0,0,0.7); animation: slideUp 0.2s ease;
}

/* ── LIGHTBOX ── */
#lightbox {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.92);
  z-index: 600;
  align-items: center; justify-content: center; flex-direction: column;
  backdrop-filter: blur(12px);
}
#lightbox.open { display: flex; animation: lbIn 0.18s ease both; }
@keyframes lbIn { from{opacity:0} to{opacity:1} }

#lb-canvas {
  max-width: 88vw; max-height: 80vh;
  border-radius: 10px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.9);
  image-rendering: high-quality;
  will-change: transform; transform: translateZ(0);
  animation: imgPop 0.24s cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes imgPop { from{transform:translateZ(0) scale(0.93);opacity:0} to{transform:translateZ(0) scale(1);opacity:1} }

#lb-img {
  display: none; max-width: 88vw; max-height: 80vh;
  border-radius: 10px; box-shadow: 0 24px 80px rgba(0,0,0,0.9);
  image-rendering: high-quality;
  will-change: transform; transform: translateZ(0);
  animation: imgPop 0.24s cubic-bezier(0.22,1,0.36,1) both;
}

.lb-controls { position: absolute; top: 14px; right: 18px; display: flex; gap: 7px; z-index: 10; }
.lb-btn {
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14);
  color: var(--text); width: 36px; height: 36px; border-radius: 8px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.14s; backdrop-filter: blur(6px); position: relative;
  font-size: 14px;
}
.lb-btn:hover { background: rgba(255,255,255,0.15); border-color: var(--accent); }
